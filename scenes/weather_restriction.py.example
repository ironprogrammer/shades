SCHEDULE = {
    "enabled": True,
    "time": "10:00",
    "days": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"],
}

SHADES = {
    "Your Shade Name": 88,  # 22% open — blocks direct sun
}
TEMP_THRESHOLD = 75  # only run when today's high exceeds this (matches TEMP_UNIT in .env)


def should_run(ctx):
    high = ctx["weather"].get("high_f")
    return high is not None and high > TEMP_THRESHOLD


async def run(hub):
    from hub import apply_shades
    await apply_shades(hub, SHADES)
