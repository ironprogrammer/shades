# ── Hub ───────────────────────────────────────────────────────────────────────
HUB_IP=192.168.x.x

# ── Battery alerts (Resend) ───────────────────────────────────────────────────
# Sign up at https://resend.com — free tier is sufficient
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Battery Check <you@yourdomain.com>"
EMAIL_TO=you@youremail.com

# ── Location ──────────────────────────────────────────────────────────────────
# IANA timezone name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Los_Angeles
# fahrenheit or celsius
TEMP_UNIT=fahrenheit
# Decimal lat/lon for weather + sunset via Open-Meteo (https://www.latlong.net)
WEATHER_LAT=33.8121
WEATHER_LON=-117.9190

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Must match the cron interval in your crontab (default: 5)
POLL_INTERVAL_MINUTES=5

# ── School calendar ───────────────────────────────────────────────────────────
# iCal feed URL for your school district's no-school/holiday calendar.
# Used to suppress wake scenes on days off and during summer.
# Many districts publish iCal feeds — check your district's calendar page.
SCHOOL_CALENDAR_ICS_URL=https://your-district.edu/calendar.ics
