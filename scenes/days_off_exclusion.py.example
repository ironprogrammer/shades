SCHEDULE = {
    "enabled": True,
    "time": "07:30",
    "days": ["mon", "tue", "wed", "thu", "fri"],
}

SHADES = ["Your Shade Name"]
POSITION = 0  # fully open


def should_run(ctx):
    # skips holidays, school breaks, and summer — requires SCHOOL_CALENDAR_ICS_URL in .env
    return ctx["is_school_day"]


async def run(hub):
    from hub import move_shade
    for shade in SHADES:
        await move_shade(hub, shade, POSITION)
