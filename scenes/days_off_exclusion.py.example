SCHEDULE = {
    "enabled": True,
    "time": "07:30",
    "days": ["mon", "tue", "wed", "thu", "fri"],
}

SHADES = {
    "Your Shade Name": 0,  # fully open
}


def should_run(ctx):
    # skips holidays, school breaks, and summer — requires SCHOOL_CALENDAR_ICS_URL in .env
    return ctx["is_school_day"]


async def run(hub):
    from hub import apply_shades
    await apply_shades(hub, SHADES)
