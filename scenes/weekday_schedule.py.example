SCHEDULE = {
    "enabled": True,
    "time": "07:30",
    "days": ["mon", "tue", "wed", "thu", "fri"],
}

SHADES = ["Your Shade Name"]
POSITION = 0  # 0 = open, 100 = closed


def should_run(ctx):
    return True


async def run(hub):
    from hub import move_shade
    for shade in SHADES:
        await move_shade(hub, shade, POSITION)
